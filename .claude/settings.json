{
    "env": {
      "ENABLE_TOOL_SEARCH": "true",
      "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
    },
    "attribution": {
      "commit": "",
      "pr": ""
    },
    "permissions": {
      "allow": []
    },
    "model": "haiku",
    "statusLine": {
      "type": "command",
      "command": "source ~/Work/personal/dotfiles/.claude/scripts/context-bar.sh"
    },
    "hooks": {
          "SessionEnd": [
              {
                  "hooks": [
                      {
                          "type": "command",
                          "command": "bash ~/Work/personal/dotfiles/.claude/scripts/add-date-to-plans.sh"
                      }
                  ]
              }
          ]
      },
    "plansDirectory": ".claude/plans/",
    "defaultMode": "plan"
  }
